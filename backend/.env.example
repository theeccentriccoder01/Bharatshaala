# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=your_very_secure_random_flask_secret_key_here

# JWT Configuration  
JWT_SECRET_KEY=your_very_secure_random_jwt_secret_key_here

# Database Configuration
DATABASE_URL=sqlite:///bharatshaala.db

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_live_your_actual_production_key_id
RAZORPAY_KEY_SECRET=your_actual_production_key_secret

# Upload Configuration
UPLOAD_FOLDER=uploads

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://bharatshaala.com

# Email Configuration (Optional)
MAIL_SERVER=your_smtp_server
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password

# Redis Configuration (for rate limiting and caching)
# Development: Use in-memory storage or local Redis
# Production: Use persistent Redis server
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

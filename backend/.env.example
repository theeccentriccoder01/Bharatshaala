# Flask
FLASK_APP=base.py
FLASK_ENV=development

# Security (generate strong random values for production)
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database (SQLite - path relative to backend/)
# Leave unset to use default: sql.db
# DATABASE_URL=sqlite:///sql.db

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS (comma-separated origins, use * for all)
CORS_ORIGINS=http://localhost:3000

# File Uploads
UPLOAD_FOLDER=uploads

# Rate Limiting (uses in-memory by default; set Redis URL for production)
# REDIS_URL=redis://localhost:6379
